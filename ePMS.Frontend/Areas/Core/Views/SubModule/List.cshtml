<div class="modal fade" id="ServiceGroup" tabindex="-1" role="dialog" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog" style="max-height:auto; max-width:450px;">
        <div class="modal-content bha-modal-content" style="min-height: 230px !important;">
            <div class="modal-header bha-modal-header">
                <div class="card-header card-header-divider col-lg-11">
                    <span id="modalHeadingDocument" class="caption-subject bold bha-modal-header-text">Service Group</span>
                </div>
                <div class="col-1 text-end">
                    <i class="bi bi-x-circle-fill fs-3 green cursor-pointer" onclick="closeModal();"></i>
                </div>
            </div>
            <div class="modal-body bha-modal-body">
                <form id="SubModuleForm">
                    <input type="hidden" id="ID" value="0" />
                   
                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="selector">
                                <label class="bha-label">
                                    Description
                                    <span class="required">*</span>
                                </label>
                                <input class="js-states form-control bha-input w-100" id="Description" required />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="selector">
                                <label class="bha-label">
                                    Url
                                    <span class="required">*</span>
                                </label>
                                <input class="js-states form-control bha-input w-100" id="Url" required />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="selector">
                                <label class="bha-label">
                                    Is Parent
                                    <span class="required">*</span>
                                </label>
                                <input class="js-states form-control bha-input w-100" id="IsParent" required />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="selector">
                                <label class="bha-label">
                                    Parent
                                    <span class="required">*</span>
                                </label>
                                <input class="js-states form-control bha-input w-100" id="ParentID" required />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="selector">
                                <label class="bha-label">
                                    Menu Order
                                    <span class="required">*</span>
                                </label>
                                <input class="js-states form-control bha-input w-100" id="MenuOrder" required />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="selector">
                                <label class="bha-label">
                                    Icon Class
                                    <span class="required">*</span>
                                </label>
                                <input class="js-states form-control bha-input w-100" id="IconClass" required />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="selector">
                                <label class="bha-label">
                                    Module
                                    <span class="required">*</span>
                                </label>
                                <input class="js-states form-control bha-input w-100" id="ModuleID" required />
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer d-flex justify-content-end pe-3">
                <button type="button" onclick="saveRecord()" class="btn-green" id="saveData">
                    <i class="bi bi-plus fs-6"></i>Save
                </button>
                <button type="button" class="btn btn-outline-secondary btn-bha-default" onclick="closeModal();">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<script src="~/NewContent/assets/js/real-estate/select2.min.js?v=@System.Configuration.ConfigurationManager.AppSettings["JSVersion"]"></script>

<script>
       $(document).ready(function () {
     loadTableData();

           //$('#saveData').on('click', function () {
           //    saveRecord();
           //});
     
 });

 function loadTableData() {
     

     ajaxRequest({ url: "/Core/SubModule/GetAll", type: 'POST', data: {}, callBack: loadTableDataCallBack });
 }
 var loadTableDataCallBack = function (responseJSON) {
     if (responseJSON.IsSuccess) {

         generateTableRowsFromJSON(responseJSON.resultJSON,'@dataTablePartialViewInputViewModel.TableIdAttr');
         tableWidth100Percent('@dataTablePartialViewInputViewModel.TableIdAttr');

     }
     else {
         errorToastr(responseJSON.Message, "error");
     }
 }
    function openModal() {
        $('#ServiceGroup').modal('show');
    }

    function closeModal() {
        $('#ServiceGroup').modal('hide');
    }
    function saveRecord() {
        if (customValidateForm('SubModuleForm')) {
            var inputJSON = getFormDataAsJSONObject("SubModuleForm");

            ajaxRequest({
                url: "/Core/SubModule/Save",
                type: 'POST',
                data: inputJSON,
                callBack: saveRecordCallBack
            });
          
        }

    }

    function saveRecordCallBack(responseJSON) {
        if (responseJSON.IsSuccess) {
            successToastr("The record has been saved successfully", 'success');
            loadTableData();
            closeModal();
            document.getElementById("SubModuleForm").reset();
        }
        else {
            errorToastr(responseJSON.Message, 'error');
        }
    }

    function deleteRecord(id = 0) {
        swal.fire({
            title: swalConfirmTitle,
            type: "warning",
            text: swalConfirmText,
            showCancelButton: true,
            confirmButtonText: swalConfirmButtonText,
            cancelButtonText: swalConfirmCancelButtonText,
            closeOnConfirm: false,
            closeOnCancel: true
        }).then(
            function (isConfirm) {
                if (isConfirm.value == true) {
                    ajaxRequest({ url: "/Core/SubModule/Delete", type: 'POST', data: { ID: id }, callBack: deleteRecordCallBack });
                } else {
                    swal.fire("Cancelled", "Your operation Canceled :)", "error");
                }
            });
    }
    function deleteRecordCallBack(responseJSON) {
        if (responseJSON.IsSuccess) {
            loadTableData();
            successToastr(responseJSON.Message, 'success');
        }
        else {
            errorToastr(responseJSON.Message, 'error');
        }
    }
</script>