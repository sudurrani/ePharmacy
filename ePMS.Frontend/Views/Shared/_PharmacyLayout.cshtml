                });
            });
        });
        function GetAllBranch(SelectedBranchID) {
            SelectedBranchID = (SelectedBranchID ?? "").toString();   // always a string

            // ---------- build the static part of the list ----------
            var $dd = $("#BranchDropdown").empty();

            var $defaultOpt = $('<option disabled value="">Select Branch</option>');
            if (SelectedBranchID === "" || SelectedBranchID === "undefined") {
                $defaultOpt.prop("selected", true);
            }
            $dd.append($defaultOpt);

            var $allOpt = $('<option value="0">All Assigned Branch</option>');
            if (SelectedBranchID === "0") {
                $allOpt.prop("selected", true);
            }
            $dd.append($allOpt);

            // Default Branch logic for Employees
            var defaultBranchID = '@Session["DefaultBranchID"]';
            var employeeID = '@Session["EmployeeID"]';

            // If no branch selected and it's an employee, use default and sync session
            if ((SelectedBranchID === "" || SelectedBranchID === "undefined" || SelectedBranchID === "null") && employeeID != "0" && employeeID != "") {
                SelectedBranchID = defaultBranchID.toString();
                $.ajax({
                    url: '/CoreSuite/SetBranchIDInSession',
                    type: 'POST',
                    data: { branchID: SelectedBranchID },
                    success: function () {
                        location.reload();
                    }
                });
                return;
            }

            // ---------- pull the branches ----------
            $.ajax({
                url: '/CoreSuite/GetAllBranch',
                type: 'POST',
                headers: { '__RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                data: JSON.stringify({ BranchID: SelectedBranchID }),
                contentType: 'application/json; charset=utf-8',
                success: function (result) {
                    if (result && result !== "Error") {
                        var parsedData = $.parseJSON(result);

                        $.each(parsedData, function (_, branch) {
                            var opt = $('<option></option>')
                                .val(branch.ID)               // or branch.BranchID – use the same field everywhere
                                .text(branch.Description);

                            if (branch.ID.toString() === SelectedBranchID) {
                                opt.prop("selected", true);
                            }
                            $dd.append(opt);
                          //  $("#BranchDropdown").select2();
                        }); $dd.select2(); select2Init($dd);
                    } else {
                        swal.fire("", "Something went wrong while loading branches. (Error Code: 400)", "error");
                    }
                },
                error: function (xhr) {
                    swal.fire("", "AJAX failed. Error Code: " + xhr.status, "error");
                }
            });
        }

    </script>

    <script>

        // Select all custom dropdowns
        const customSelects = document.querySelectorAll(".custom-select");

        customSelects.forEach((select) => {
            const selected = select.querySelector(".select-selected");
            const items = select.querySelector(".select-items");

            // Toggle dropdown
            selected.addEventListener("click", (e) => {
                closeAllDropdowns();
                items.classList.toggle("active");
                e.stopPropagation();
            });

            // Select item
            items.querySelectorAll("div").forEach((item) => {
                item.addEventListener("click", () => {
                    selected.textContent = item.textContent;
                    items.classList.remove("active");
                });
            });
        });

        // Close all dropdowns if clicked outside
        window.addEventListener("click", closeAllDropdowns);

        function closeAllDropdowns() {
            document.querySelectorAll(".select-items").forEach((items) => {
                items.classList.remove("active");
            });
        }
    </script>

