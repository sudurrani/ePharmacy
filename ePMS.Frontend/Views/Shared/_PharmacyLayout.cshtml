<script>    
    $(function () {        
        const distinctModules = Object.values(
            menuJSON.reduce((acc, item) => {
                acc[item.ModuleID] = {
                    ModuleID: item.ModuleID,
                    Module: item.Module
                };
                return acc;
            }, {})
        );
        let allMenus = '', chunkSize = 8;
        for (let i = 0; i < distinctModules.length; i += chunkSize) {
            let chunk = distinctModules.slice(i, i + chunkSize);
            //console.log("Chunk:", chunk);
            let active = i == 0 ? 'active' : '';
            allMenus += `<div class="carousel-item ${active}">
                         <div class="nav2-menu">
                             <nav class="navbar navbar-expand-lg">
                                 <div class="collapse navbar-collapse show">
                                     <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        `;



            $.each(chunk, function (moduleIndex, module) {
                //let distinctModulesChunk = distinctModules.splice(((moduleIndex+1)*8))

                let parentMenus = menuJSON.filter(row => row.ModuleID == module.ModuleID && row.IsParent == true)
                    .sort((a, b) => a.SubModuleOrder - b.SubModuleOrder);

                allMenus +=
                    `
                      <li class="nav-item dropdown" id="Mdl-${module.ModuleID}">
                          <a class="nav-link bha-menu-top dropdown-toggle" href="javascript:void(0)" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">${module.Module}</a>
                          <ul class="dropdown-menu bha-dp bha-dp-w">
                    `;
                $.each(parentMenus, function (index, subModule) {
                    let forms = menuJSON.filter(row => row.ParentID == subModule.SubModuleID && row.IsParent == false)
                        .sort((a, b) => a.SubModuleOrder - b.SubModuleOrder);


                    let formsInParentMenu = '';
                    $.each(forms, function (index, form) {                        
                        formsInParentMenu +=
                            `
                            <li class="menu-item active">
                                <a class="bha-link" href="${form.Url}?FID=${encryptNumber(form.ModuleID)}&ModuleID=${encryptNumber(form.SubModuleID)}" role="button" aria-expanded="false" style="text-decoration:none;">
                                    <span class="dot"></span><span>${form.SubModule}</span>
                                </a>
                            </li>
                          `;
                    });
                    allMenus +=
                        `
                          <div class="accordion position-relative bha-submenu" id="sidebarAccordion-${subModule.SubModuleID}">
                              <div class="vertical-line"></div>
                              <div class="accordion-item border-0" style="background-color: transparent;">
                                  <h2 class="accordion-header" id="heading-${subModule.SubModuleID}"><button class="accordion-button-bha collapsed"
                                          type="button" data-bs-toggle="collapse" data-bs-target="#collapseProduct-${subModule.SubModuleID}"
                                          aria-expanded="false" aria-controls="collapseProduct-${subModule.SubModuleID}"><i
                                              class="bi bi-chevron-down submenu-chevron"></i>${subModule.SubModule}</button></h2>
                                  <div id="collapseProduct-${subModule.SubModuleID}" class="accordion-collapse collapse" aria-labelledby="heading-${subModule.SubModuleID}"
                                      data-bs-parent="#sidebarAccordion-${subModule.SubModuleID}">
                                      <div class="accordion-body px-2 pt-2 pb-0">
                                          <ul class="list-unstyled">
                                              ${formsInParentMenu}
                                          </ul>
                                      </div>
                                  </div>
                              </div>
                          </div>
                        `;
                });
                allMenus += `  </ul></li>`;

            });
            allMenus += `</ul>
                 </div>
             </nav>
         </div>
         </div>`
            $('#GeneratedMenus').html(allMenus);
        }

    });
</script>
