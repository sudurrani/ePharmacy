            }

        th.no-sort::after,
        th.no-sort.sorting::after,
        th.no-sort.sorting_asc::after,
        th.no-sort.sorting_desc::after {
            display: none !important;
        }

        .LockOn {
            display: block;
            display: none;
            visibility: visible;
            position: absolute;
            z-index: 10051;
            top: -165px;
            left: 0px;
            width: 100vw;
