    <script>
       // localStorage.setItem('DefaultCurrencyID', (@Session["CurrencyID"] != null ? @Session["CurrencyID"].ToString() : null));
          localStorage.setItem('DefaultCurrencyID', '@(Session["CurrencyID"] ?? "")');
        $(document).ready(function () {


            $(document).on("click", ".calendar-trigger i", function () {
                $(this).siblings("input").trigger("click");
            });

            $('#PinEmailAddress').on('input', function () {
                CheckEmailAddress();
            });

            $("#BranchDropdown").select2();
           var sessionBranchID = '@Session["BranchID"]'; // Razor to inject server-side value

            ///Loading Screen ajax send and close
            $(document).ajaxSend(function (event, jqxhr, settings) {
                if (window.skipLoaderForSwitch) {
                    return; // Don't show loader
                }
                //console.log(settings.url);

                if (settings.url != "/Notification/GetNotifications?{}" && settings.url != "/UserManagement/OnlineUser/GetTableSummary") {
                    $('#coverScreen').show();
                }
            });
            $(document).bind("ajaxStop.mine", function () {

                $('#coverScreen').hide();
            });
            GetAllBranch(sessionBranchID);

            $('#BranchDropdown').on('change', function () {
                var selectedBranchID = $(this).val();

                $.ajax({
                    url: '/CoreSuite/SetBranchIDInSession',
                    type: 'POST',
