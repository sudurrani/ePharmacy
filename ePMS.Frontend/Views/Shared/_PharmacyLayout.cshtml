    <style>
        /* Right side modal container */
        .right-side-modal .modal-dialog {
            position: fixed;
            top: 0;
            right: 0;
            margin: 0;
            height: 50%;
            width: 420px;
            max-width: 100%;
        }

        /* Modal content layout */
        .right-side-modal .modal-content {
            height: 100%;
            border-radius: 0;
            display: flex;
            flex-direction: column;
        }

        /* Modal body should scroll, footer fixed */
        .right-side-modal .modal-body {
            flex: 1;
            overflow-y: auto;
            padding-bottom: 1rem;
        }

        /* Footer always visible */
        .right-side-modal .modal-footer {
            border-top: 1px solid #e5e5e5;
        }

        /* Slide animation */
        .right-side-modal.fade .modal-dialog {
            transform: translateX(100%);
            transition: transform 0.3s ease-in-out;
        }

        .right-side-modal.fade.show .modal-dialog {
            transform: translateX(0);
        }

        /* Select2 fix */
        /*#ddlCompanyPIN + .select2-container {
            z-index: 1060 !important;
        }
        #ddlCompanyPIN + .select2-container--open {
            z-index: 1060 !important;
        }*/



        /*table Header Fixed CSS Start Here!*/
        .table-scroll-wrapper {
            max-height: 500px;
            overflow-y: auto;
            width: 100%;
            border: none;
        }


        .bhaexampletable {
            border-collapse: collapse;
            width: 100%;
        }

            .bhaexampletable thead {
                position: sticky;
                top: 0;
                z-index: 10;
                background-color: #1d3557;
                color: #ffffff;
            }

                .bhaexampletable thead tr td,
                .bhaexampletable thead tr th {
                    background-color: #f7f9fc !important;
                    /*color: #ffffff;*/
                }

            .bhaexampletable .sort-icon {
                opacity: 0.7;
                transition: opacity 0.2s;
            }

                .bhaexampletable .sort-icon:hover {
                    opacity: 1;
                }

        /* table Header Fixed CSS End Here!*/

        .customZIndex {
            z-index: 1057 !important;
        }

        .bha-mb-vc-select {
            position: relative;
            width: 220px;
        }

        .bha-mb-vc-box {
            border: 1px solid #ccc;
            border-radius: 4px;
            padding: 6px 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
        }

        .form-control:disabled {
