

@{ System.Collections.Specialized.NameValueCollection NVC = Request.QueryString;
    long companyid = 0;
    long moduleid = 0;
    var UID = Session["UserID"];
    var PID = Session["ProjectID"];
    var SubModuleID = Session["SubModuleID"];
    var BranchID = Session["BranchID"];
    var DefaultBranchID = Session["DefaultBranchID"];
    var EmployeeID = Session["EmployeeID"];
    var UserName = Session["UserName"];


    companyid = Session["CompanyID"] != null ? long.Parse(Session["CompanyID"].ToString()) : Convert.ToInt64("0");
    //companyid = long.Parse(Session["CompanyID"].ToString());
    if (NVC.HasKeys())
    {
        if (NVC.GetKey(0) == "ModuleID")
        {
            if (NVC.Get(0).ToString() == "14")
            {
                Session["ModuleID"] = "14";
            }
            else

            {
                Session["ModuleID"] = ePMS.Frontend.CommonClasses.URLcoding.Decode(NVC.Get(0).ToString());
            }
            moduleid = long.Parse(Session["ModuleID"].ToString());
        }
    }
    string currentUrl = HttpContext.Current.Request.RawUrl;
    //string CurrentTimeStamp = DateTime.Now.Ticks.ToString() + "" + Session["UserID"].ToString();
    string CurrentTimeStamp = DateTime.Now.Ticks.ToString() + "" + (Session["UserID"] != null ? Session["UserID"].ToString() : "0");
