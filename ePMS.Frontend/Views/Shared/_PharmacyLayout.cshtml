    string CompanyType = Session["CompanyType"] != null ? Session["CompanyType"].ToString() : "";
    string RoleName = Session["UserRoleName"] != null ? Session["UserRoleName"].ToString() : "";

    string UserImg = Session["UserImg"] != null ? Session["UserImg"].ToString() : "";

}
