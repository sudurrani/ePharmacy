                    </div>
                </div>
            </div>

            <!-- Sales Return -->
            <div class="col-md-3">
                <div class="card">
                    <div class="card-content">
                        <div class="left-block">
                            <div class="icon">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </div>
                            <div class="text">
                                <h4>Sales Return</h4>
                                <h2>$2,274.05</h2>
                            </div>
                        </div>
                        <div class="percent-text">
                            <span class="change positive">+10%</span>
                            <p>from the last year</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Purchase Return -->
