<script>
    $(document).ready(function () {

        /*  Donut Chart (Top 3 Customers) */
        let donutResponse = [
            { name: "Wade Warren", value: 50 },
            { name: "Qurban Ali", value: 30 },
            { name: "Aurang Zaib", value: 20 }
        ];

        let donutLabels = donutResponse.map(item => item.name);
        let donutValues = donutResponse.map(item => item.value);
        let donutColors = ["#046F76", "#07A6B1", "#70BAC0"];

        const donutCtx = document.getElementById('donutChart').getContext('2d');
        new Chart(donutCtx, {
            type: 'doughnut',
            data: {
                datasets: [
                    {
                        data: donutValues,
                        backgroundColor: donutColors,
                        borderWidth: 1,
                        borderColor: '#FFFFFF',
                        borderAlign: 'inner',
                        cutout: '45%',
                        radius: '85%'
                    },
                    {
                        data: [100],
                        backgroundColor: ['#f0f0f0'],
                        borderWidth: 0,
                        cutout: '60',
                        radius: '85%'
                    }
                ],
                labels: donutLabels
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                if (context.datasetIndex === 0) {
                                    return `${context.label}: ${context.formattedValue}%`;
                                }
                                return null;
                            }
                        }
                    }
                }
            }
        });

        let donutLegend = $(".custom-legend").empty();
        donutResponse.forEach((item, i) => {
            donutLegend.append(`
                                        <div class="legend-block">
                                            <div class="legend-group">
                                                <span class="legend-color" style="background-color: ${donutColors[i]};"></span>
                                                <span class="legend-name">${item.name}</span>
                                            </div>
                                            <div class="legend-percent">${item.value}%</div>
                                        </div>
                                    `);
        });


        /*  Combo Chart (Sales Order) */
        let comboResponse = {
            years: ['2018', '2019', '2020', '2021', '2022', '2023'],
            released: [10, 11, 15, 15, 13, 20],
            open: [25, 30, 10, 8, 18, 25],
            trend: [35, 41, 25, 23, 31, 45],
            percentage: "↑ 2.2%",
            legends: [
                { label: "Released", color: "#046F76" },
                { label: "Open", color: "#75C0C44D" }
            ]
        };

        const comboCtx = document.getElementById('comboChart').getContext('2d');
        new Chart(comboCtx, {
            data: {
                labels: comboResponse.years,
                datasets: [
                    {
                        type: 'bar',
                        label: 'Released',
                        data: comboResponse.released,
                        backgroundColor: '#046F76',
                        stack: 'stacked',
                        barThickness: 20,
                        categoryPercentage: 0.1,
                        barPercentage: 0.8
                    },
                    {
                        type: 'bar',
                        label: 'Open',
                        data: comboResponse.open,
                        backgroundColor: '#75C0C44D',
                        stack: 'stacked',
                        barThickness: 20,
                        categoryPercentage: 0.8,
                        barPercentage: 0.8
                    },
                    {
                        type: 'line',
                        label: 'Trend',
                        data: comboResponse.trend.map(v => v + 5),
                        borderColor: '#E6E6E6',
                        fill: false,
                        pointBackgroundColor: '#008080',
                        pointRadius: 5,
                        borderWidth: 2,
                        lineTension: 0.1,
                        borderCapStyle: 'round'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { stacked: true, ticks: { maxRotation: 0, minRotation: 0 }, grid: { display: false } },
                    y: { stacked: true, ticks: { display: false, beginAtZero: true, padding: 10 }, grid: { display: false } }
                },
                plugins: { legend: { display: false } }
            }
        });

        let comboLegendContainer = $(".combo-legend-container").empty();
        comboLegendContainer.append(`
                                    <div class="percentage">
                                        <span>${comboResponse.percentage}</span>
                                    </div>
                                `);
        comboResponse.legends.forEach(item => {
            comboLegendContainer.append(`
                                        <div class="combo-legend-item">
                                            <div class="combo-legend-color" style="background-color: ${item.color};"></div>
                                            ${item.label}
                                        </div>
                                    `);
        });



        /* 4️⃣ Donut Chart (Top 3 Vendors) */
        let vendorResponse = [
            { name: "David Miller", value: 65 },
            { name: "Alex John", value: 25 },
            { name: "Chris Lee", value: 10 }
        ];

        let vendorLabels = vendorResponse.map(item => item.name);
        let vendorValues = vendorResponse.map(item => item.value);
        let vendorColors = ["#70BAC0", "#07A6B1", "#046F76"];

        const vendorCtx = document.getElementById('donutChartVendor').getContext('2d');
        new Chart(vendorCtx, {
            type: 'doughnut',
            data: {
                datasets: [
                    {
                        data: vendorValues,
                        backgroundColor: vendorColors,
                        borderWidth: 1,
                        borderColor: '#FFFFFF',
                        borderAlign: 'inner',
                        cutout: '45%',
                        radius: '85%'
                    },
                    {
                        data: [100],
                        backgroundColor: ['#f0f0f0'],
                        borderWidth: 0,
                        cutout: '60',
                        radius: '85%'
                    }
                ],
                labels: vendorLabels
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                if (context.datasetIndex === 0) {
                                    return `${context.label}: ${context.formattedValue}%`;
                                }
                                return null;
                            }
                        }
                    }
                }
            }
        });

        let vendorLegend = $("#legendVendor").empty();
        vendorResponse.forEach((item, i) => {
            vendorLegend.append(`
                                    <div class="legend-block">
                                        <div class="legend-group">
                                            <span class="legend-color" style="background-color: ${vendorColors[i]};"></span>
                                            <span class="legend-name">${item.name}</span>
                                        </div>
                                        <div class="legend-percent">${item.value}%</div>
                                    </div>
                                `);
        });

        /* ---------- Static full-year data (you'll replace with backend later) ---------- */
        const allMonths = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        const monthDates = allMonths.map((m, i) => new Date(2025, i, 1));

        const baseData = {
            labels: allMonths.slice(),
            datasets: [
                { label: 'Production Cost', data: [20000, 25000, 22000, 21000, 25000, 27000, 26000, 24000, 23000, 22000, 24000, 26000], color: '#007b83' },
                { label: 'Labour Cost', data: [15000, 18000, 14000, 20000, 22000, 19000, 19000, 18500, 18000, 17500, 17000, 19000], color: '#009eac' },
                { label: 'Manufacturing Cost', data: [5000, 8000, 10000, 12000, 15000, 13000, 11000, 10000, 9000, 8000, 7000, 12000], color: '#00bfb3' }
            ]
        };

        /* ---------- Helpers ---------- */
        function filterByDateRange(startDate, endDate) {
            const indices = monthDates
                .map((d, i) => (d >= startDate && d <= endDate) ? i : -1)
                .filter(i => i >= 0);

            if (!indices.length) return { labels: [], datasets: baseData.datasets.map(ds => ({ ...ds, data: [] })) };

            const labels = indices.map(i => baseData.labels[i]);
            const datasets = baseData.datasets.map(ds => ({
                label: ds.label,
                color: ds.color,
                data: indices.map(i => ds.data[i])
            }));

            return { labels, datasets, indices };
        }

        /* ---------- Chart instance ---------- */
        let lineChart = null;
        let currentCenterLabel = null;

        function createProductionGradient(ctx) {
            const g = ctx.createLinearGradient(0, 0, 0, ctx.canvas.height);
            g.addColorStop(0, "rgba(0, 123, 131, 0.30)");
            g.addColorStop(1, "rgba(0, 123, 131, 0)");
            return g;
        }

        function buildOrUpdateLineChart(filtered) {
            const ctx = document.getElementById('lineChart').getContext('2d');

            if (filtered.labels.length) {
                const midIndex = Math.floor(filtered.labels.length / 2);
                currentCenterLabel = filtered.labels[midIndex];
            } else {
                currentCenterLabel = null;
            }

            const chartDatasets = [
                {
                    label: filtered.datasets[0].label,
                    data: filtered.datasets[0].data,
                    borderColor: filtered.datasets[0].color,
                    tension: 0.4,
                    fill: true,
                    backgroundColor: createProductionGradient(ctx),
                    pointBackgroundColor: '#fff',
                    pointBorderColor: filtered.datasets[0].color,
                    pointRadius: 5,
                    borderWidth: 2
                },
                {
                    label: filtered.datasets[1].label,
                    data: filtered.datasets[1].data,
                    borderColor: filtered.datasets[1].color,
                    tension: 0.4,
                    fill: false,
                    pointRadius: (ctx) => (currentCenterLabel && ctx.dataIndex === filtered.labels.indexOf(currentCenterLabel)) ? 5 : 0,
                    pointBackgroundColor: filtered.datasets[1].color,
                    borderWidth: 2
                },
                {
                    label: filtered.datasets[2].label,
                    data: filtered.datasets[2].data,
                    borderColor: filtered.datasets[2].color,
                    tension: 0.4,
                    fill: false,
                    pointRadius: (ctx) => (currentCenterLabel && ctx.dataIndex === filtered.labels.indexOf(currentCenterLabel)) ? 5 : 0,
                    pointBackgroundColor: filtered.datasets[2].color,
                    borderWidth: 2
                }
            ];

            if (lineChart) {
                lineChart.data.labels = filtered.labels;
                lineChart.data.datasets = chartDatasets;
                lineChart.options.scales.x.grid.color = c =>
                    (currentCenterLabel && c.tick && c.tick.label === currentCenterLabel) ? '#bdbdbd' : 'transparent';
                lineChart.data.datasets[0].backgroundColor = createProductionGradient(ctx);
                lineChart.update();
                return;
            }

            lineChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: filtered.labels,
                    datasets: chartDatasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: '#fff',
                            borderColor: '#ddd',
                            borderWidth: 1,
                            titleColor: '#111',
                            bodyColor: '#111',
                            callbacks: {
                                label: ctx => `${ctx.dataset.label}: ${ctx.formattedValue}`
                            }
                        }
                    },
                    interaction: { mode: 'nearest', axis: 'x', intersect: false },
                    scales: {
                        x: {
                            grid: {
                                drawTicks: false,
                                drawBorder: false,
                                color: c =>
                                    (currentCenterLabel && c.tick && c.tick.label === currentCenterLabel) ? '#bdbdbd' : 'transparent'
                            }
                        },
                        y: {
                            min: 5000,
                            max: 30000,
                            ticks: {
                                stepSize: 5000,
                                callback: v => (v / 1000) + 'K'
                            },
                            grid: { display: false }
                        }
                    }
                }
            });
        }

        /* ---------- Datepicker init and wiring ---------- */
        (function initDateRangeAndChart() {
            // default range = full year (Jan 1, 2025 to Dec 31, 2025)
            const defaultStart = new Date(2025, 0, 1);
            const defaultEnd = new Date(2025, 11, 31);

            /* Attach flatpickr to calendar icon */
            flatpickr("#calendarIcon", {
                mode: "range",
                dateFormat: "M d, Y",
                defaultDate: [defaultStart, defaultEnd],
                appendTo: document.getElementById("dateWrapper"),
                onClose: function (selectedDates) {
                    if (selectedDates.length === 2) {
                        const [start, end] = selectedDates;

                        // update visible text
                        const dStr =
                            flatpickr.formatDate(start, "M d, Y") +
                            " - " +
                            flatpickr.formatDate(end, "M d, Y");
                        $("#dateRange").text(dStr);

                        // filter and update chart
                        const filtered = filterByDateRange(start, end);
                        buildOrUpdateLineChart(filtered);
                    }
                }
            });

            // initial chart (full year)
            const initialFiltered = filterByDateRange(defaultStart, defaultEnd);
            buildOrUpdateLineChart(initialFiltered);

            // build initial legend
            const legend = $(".line-chart-legend").empty();
            baseData.datasets.forEach(ds => {
                legend.append(
                    `<div class="legend-item"><span class="legend-color" style="background:${ds.color}"></span>${ds.label}</div>`
                );
            });

        })();

        /*   alert and reminder js*/
        const tabs = document.querySelectorAll(".tab");
        const contents = document.querySelectorAll(".tab-content");

        tabs.forEach(tab => {
            tab.addEventListener("click", () => {
                tabs.forEach(t => t.classList.remove("active"));
                contents.forEach(c => c.classList.remove("active"));

                tab.classList.add("active");
                document.querySelector(`.tab-content.${tab.dataset.target}`).classList.add("active");
            });
        });
    });

</script>
