                    <div class="card-content">
                        <div class="left-block">
                            <div class="icon">
                                <i class="bi bi-receipt"></i>
                            </div>
                            <div class="text">
                                <h4>Purchase Return</h4>
                                <h2>$2,274.05</h2>
                            </div>
                        </div>
                        <div class="percent-text">
                            <span class="change negative">-25%</span>
                            <p>from the last year</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        @*card html end*@

        @*charts html start*@
        <div class="row mt-30 mx-15">
            <div class=" col-md-4">
                <div class="chart-container">
                    <div class="chart-title">
                        <div class="chart-title-icon">
                            <i class="bi bi-pie-chart"></i>
                        </div>
                        <label>Top 3 Customer By Balance</label>
                    </div>
                    <div class="chart-wrapper">
                        <canvas id="donutChart" style="height: 218px; width: 332px;"></canvas>
                    </div>
                    <!-- Legend will be generated dynamically -->
                    <div class="custom-legend"></div>
                </div>
            </div>
            <div class=" col-md-4">
                <div class="combo-chart-container">
                    <div class="combo-chart-title">
                        <div class="combo-chart-title-icon">
                            <i class="bi bi-bar-chart"></i>
                        </div>
                        Sales Order
                    </div>
                    <div class="combo-chart-wrapper">
                        <canvas id="comboChart" style="height: 218px; width: 332px;"></canvas>
                    </div>
                    <div class="combo-legend-container"></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="chart-container">
                    <div class="chart-title">
                        <div class="chart-title-icon">
                            <i class="bi bi-pie-chart"></i>
                        </div>
                        <label>Top 3 Vendor By Balance</label>
                    </div>
