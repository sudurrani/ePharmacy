                        </div>
                    </div>
                </div>
            </div>

            <!-- Purchase -->
            <div class="col-md-3">
                <div class="card">
                    <div class="card-content">
                        <div class="left-block">
                            <div class="icon">
                                <i class="bi-regular bi-credit-card"></i>
                            </div>
                            <div class="text">
                                <h4>Purchase</h4>
                                <h2>$2,274.05</h2>
                            </div>
                        </div>
                        <div class="percent-text">
