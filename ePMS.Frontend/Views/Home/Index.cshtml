@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ePharmacy – Pharmacy Management System | BK-InfoTech</title>
    <link rel="icon" href="~/CompanyLogos/bk-infotech.ico" type="image/x-icon">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --gold: #E8A020;
            --gold-light: #F5C55A;
            --gold-pale: #FDF3DC;
            --brown: #3B1F0A;
            --brown-mid: #6B3A1F;
            --cream: #FEFAF3;
            --dark: #1A0D03;
            --white: #ffffff;
            --gray: #6c757d;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--brown);
            overflow-x: hidden;
        }

        h1, h2, h3, .display-font {
            font-family: 'Playfair Display', serif;
        }

        /* ── NAVBAR ── */
        .navbar {
            background: var(--dark);
            padding: 14px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 2px solid var(--gold);
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .navbar-brand img {
                height: 46px;
                width: 46px;
                border-radius: 50%;
                object-fit: contain;
                background: var(--gold);
                padding: 2px;
            }

        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 900;
            color: var(--gold);
            letter-spacing: 1px;
        }

        .brand-sub {
            font-size: 0.65rem;
            color: #aaa;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .nav-link {
            color: #ccc !important;
            font-size: 0.88rem;
            font-weight: 500;
            letter-spacing: 0.5px;
            padding: 6px 14px !important;
            transition: color 0.2s;
        }

            .nav-link:hover {
                color: var(--gold) !important;
            }

        .btn-nav-cta {
            background: var(--gold);
            color: var(--dark) !important;
            font-weight: 600;
            border-radius: 4px;
            padding: 7px 20px !important;
            transition: background 0.2s;
        }

            .btn-nav-cta:hover {
                background: var(--gold-light);
            }

        /* ── HERO ── */
        .hero {
            background: linear-gradient(135deg, var(--dark) 0%, var(--brown) 60%, #5C2E00 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

            .hero::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: radial-gradient(circle at 70% 40%, rgba(232,160,32,0.15) 0%, transparent 60%), radial-gradient(circle at 20% 80%, rgba(232,160,32,0.08) 0%, transparent 50%);
            }

        .hero-pill {
            display: inline-block;
            background: rgba(232,160,32,0.15);
            border: 1px solid rgba(232,160,32,0.4);
            color: var(--gold-light);
            font-size: 0.75rem;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            padding: 6px 18px;
            border-radius: 100px;
            margin-bottom: 24px;
        }

        .hero h1 {
            font-size: clamp(2.6rem, 5vw, 4.2rem);
            color: var(--white);
            line-height: 1.12;
            margin-bottom: 22px;
        }

            .hero h1 span {
                color: var(--gold);
            }

        .hero p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.7);
            line-height: 1.8;
            max-width: 520px;
            margin-bottom: 36px;
        }

        .btn-primary-hero {
            background: var(--gold);
            color: var(--dark);
            font-weight: 700;
            font-size: 0.95rem;
            padding: 14px 34px;
            border: none;
            border-radius: 4px;
            text-decoration: none;
            display: inline-block;
            transition: all 0.25s;
            letter-spacing: 0.5px;
        }

            .btn-primary-hero:hover {
                background: var(--gold-light);
                color: var(--dark);
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(232,160,32,0.35);
            }

        .btn-outline-hero {
            background: transparent;
            color: rgba(255,255,255,0.85);
            font-weight: 500;
            font-size: 0.95rem;
            padding: 13px 28px;
            border: 1.5px solid rgba(255,255,255,0.3);
            border-radius: 4px;
            text-decoration: none;
            display: inline-block;
            transition: all 0.25s;
        }

            .btn-outline-hero:hover {
                border-color: var(--gold);
                color: var(--gold);
            }

        .hero-visual {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(232,160,32,0.2);
            border-radius: 16px;
            padding: 30px;
            backdrop-filter: blur(10px);
            position: relative;
        }

        .hero-stat-card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(232,160,32,0.15);
            border-radius: 10px;
            padding: 18px 22px;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: background 0.2s;
        }

            .hero-stat-card:hover {
                background: rgba(232,160,32,0.08);
            }

        .stat-icon {
            width: 44px;
            height: 44px;
            background: var(--gold);
            color: var(--dark);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .stat-label {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.45);
        }

        .stat-value {
            font-size: 1rem;
            color: var(--white);
            font-weight: 600;
        }

        /* ── SECTION STYLES ── */
        .section-eyebrow {
            font-size: 0.72rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--gold);
            font-weight: 600;
            margin-bottom: 10px;
        }

        .section-title {
            font-size: clamp(1.9rem, 3.5vw, 2.8rem);
            color: var(--brown);
            margin-bottom: 14px;
            line-height: 1.2;
        }

        .section-subtitle {
            font-size: 1rem;
            color: var(--gray);
            line-height: 1.75;
            max-width: 560px;
        }

        .divider-gold {
            width: 52px;
            height: 3px;
            background: var(--gold);
            margin: 18px 0 30px;
        }

        /* ── FEATURES ── */
        .features-section {
            padding: 100px 0;
            background: var(--cream);
        }

        .feature-card {
            background: var(--white);
            border: 1.5px solid #e8dfd0;
            border-radius: 12px;
            padding: 32px 28px;
            height: 100%;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

            .feature-card::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--gold);
                transform: scaleX(0);
                transition: transform 0.3s;
            }

            .feature-card:hover {
                border-color: var(--gold);
                box-shadow: 0 12px 36px rgba(59,31,10,0.1);
                transform: translateY(-4px);
            }

                .feature-card:hover::after {
                    transform: scaleX(1);
                }

        .feature-icon {
            width: 56px;
            height: 56px;
            background: var(--gold-pale);
            color: var(--brown);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            margin-bottom: 20px;
        }

        .feature-card h5 {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            color: var(--brown);
            margin-bottom: 10px;
        }

        .feature-card p {
            font-size: 0.9rem;
            color: var(--gray);
            line-height: 1.7;
        }

        /* ── MODULES ── */
        .modules-section {
            padding: 100px 0;
            background: linear-gradient(180deg, #FDF3DC 0%, #FEFAF3 100%);
        }

        .module-tab-btn {
            background: var(--white);
            border: 1.5px solid #ddd;
            color: var(--brown-mid);
            font-weight: 500;
            padding: 10px 22px;
            border-radius: 6px;
            font-size: 0.88rem;
            cursor: pointer;
            transition: all 0.2s;
        }

            .module-tab-btn.active, .module-tab-btn:hover {
                background: var(--gold);
                border-color: var(--gold);
                color: var(--dark);
                font-weight: 600;
            }

        .module-detail-card {
            background: var(--white);
            border: 1.5px solid #e8dfd0;
            border-radius: 14px;
            padding: 40px;
        }

        .module-feature-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .module-feature-list li {
                display: flex;
                align-items: flex-start;
                gap: 12px;
                padding: 10px 0;
                border-bottom: 1px solid #f0ebe3;
                font-size: 0.92rem;
                color: var(--brown);
            }

                .module-feature-list li:last-child {
                    border-bottom: none;
                }

                .module-feature-list li i {
                    color: var(--gold);
                    font-size: 1rem;
                    margin-top: 2px;
                    flex-shrink: 0;
                }

        .module-icon-big {
            font-size: 3.5rem;
            color: var(--gold);
        }

        /* ── PRICING ── */
        .pricing-section {
            padding: 100px 0;
            background: var(--dark);
            position: relative;
            overflow: hidden;
        }

            .pricing-section::before {
                content: '';
                position: absolute;
                top: -60px;
                left: 50%;
                transform: translateX(-50%);
                width: 800px;
                height: 300px;
                background: radial-gradient(ellipse, rgba(232,160,32,0.1) 0%, transparent 70%);
            }

            .pricing-section .section-title {
                color: var(--white);
            }

            .pricing-section .section-subtitle {
                color: rgba(255,255,255,0.55);
            }

            .pricing-section .section-eyebrow {
                color: var(--gold-light);
            }

            .pricing-section .divider-gold {
                background: var(--gold);
            }

        .plan-card {
            background: rgba(255,255,255,0.04);
            border: 1.5px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 36px 30px;
            height: 100%;
            position: relative;
            transition: all 0.3s;
        }

            .plan-card:hover {
                border-color: rgba(232,160,32,0.4);
                background: rgba(255,255,255,0.06);
                transform: translateY(-5px);
            }

            .plan-card.featured {
                border-color: var(--gold);
                background: rgba(232,160,32,0.07);
            }

                .plan-card.featured:hover {
                    transform: translateY(-5px);
                }

        .popular-badge {
            position: absolute;
            top: -14px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--gold);
            color: var(--dark);
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 5px 18px;
            border-radius: 100px;
        }

        .plan-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            color: var(--white);
            margin-bottom: 6px;
        }

        .plan-tagline {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.45);
            margin-bottom: 24px;
        }

        .plan-price {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--gold);
            line-height: 1;
        }

            .plan-price sup {
                font-size: 1rem;
                vertical-align: top;
                margin-top: 8px;
            }

            .plan-price span {
                font-size: 0.9rem;
                color: rgba(255,255,255,0.4);
                font-weight: 400;
            }

        .plan-divider {
            border-top: 1px solid rgba(255,255,255,0.08);
            margin: 24px 0;
        }

        .plan-feature {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 7px 0;
            font-size: 0.88rem;
        }

            .plan-feature i.bi-check-circle-fill {
                color: var(--gold);
            }

            .plan-feature i.bi-x-circle {
                color: rgba(255,255,255,0.2);
            }

            .plan-feature.unavailable {
                color: rgba(255,255,255,0.25);
            }

            .plan-feature.available {
                color: rgba(255,255,255,0.8);
            }

        .btn-plan {
            display: block;
            width: 100%;
            padding: 13px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.9rem;
            text-align: center;
            text-decoration: none;
            margin-top: 28px;
            transition: all 0.25s;
            border: none;
            cursor: pointer;
        }

        .btn-plan-outline {
            background: transparent;
            border: 1.5px solid rgba(232,160,32,0.4);
            color: var(--gold-light);
        }

            .btn-plan-outline:hover {
                background: var(--gold);
                color: var(--dark);
            }

        .btn-plan-filled {
            background: var(--gold);
            color: var(--dark);
        }

            .btn-plan-filled:hover {
                background: var(--gold-light);
                box-shadow: 0 6px 20px rgba(232,160,32,0.3);
            }

        /* ── WHY US ── */
        .why-section {
            padding: 100px 0;
            background: var(--cream);
        }

        .why-card {
            display: flex;
            gap: 20px;
            align-items: flex-start;
            padding: 26px;
            background: var(--white);
            border: 1.5px solid #e8dfd0;
            border-radius: 12px;
            margin-bottom: 20px;
            transition: all 0.25s;
        }

            .why-card:hover {
                border-color: var(--gold);
                box-shadow: 0 8px 24px rgba(59,31,10,0.08);
            }

        .why-icon {
            width: 48px;
            height: 48px;
            background: var(--gold-pale);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: var(--brown);
            flex-shrink: 0;
        }

        .why-card h6 {
            font-family: 'Playfair Display', serif;
            font-size: 1.05rem;
            color: var(--brown);
            margin-bottom: 5px;
        }

        .why-card p {
            font-size: 0.87rem;
            color: var(--gray);
            line-height: 1.65;
            margin: 0;
        }

        /* ── TESTIMONIALS ── */
        .testimonials-section {
            padding: 100px 0;
            background: #FDF3DC;
        }

        .testimonial-card {
            background: var(--white);
            border: 1.5px solid #e8dfd0;
            border-radius: 12px;
            padding: 32px;
            height: 100%;
        }

        .stars {
            color: var(--gold);
            font-size: 0.9rem;
            margin-bottom: 14px;
        }

        .testimonial-text {
            font-size: 0.92rem;
            color: var(--brown-mid);
            line-height: 1.75;
            font-style: italic;
            margin-bottom: 22px;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .author-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1rem;
            color: var(--dark);
            flex-shrink: 0;
        }

        .author-name {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--brown);
        }

        .author-role {
            font-size: 0.78rem;
            color: var(--gray);
        }

        /* ── CTA BANNER ── */
        .cta-section {
            padding: 90px 0;
            background: linear-gradient(135deg, var(--brown) 0%, var(--dark) 100%);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .cta-section::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(ellipse at center, rgba(232,160,32,0.12) 0%, transparent 70%);
            }

            .cta-section h2 {
                color: var(--white);
                margin-bottom: 14px;
                font-size: clamp(1.8rem, 3vw, 2.6rem);
            }

            .cta-section p {
                color: rgba(255,255,255,0.6);
                font-size: 1rem;
                margin-bottom: 36px;
            }

        /* ── FOOTER ── */
        footer {
            background: var(--dark);
            padding: 70px 0 30px;
            border-top: 2px solid rgba(232,160,32,0.2);
        }

        .footer-brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            color: var(--gold);
            font-weight: 900;
        }

        .footer-desc {
            font-size: 0.87rem;
            color: rgba(255,255,255,0.45);
            line-height: 1.7;
            margin-top: 12px;
        }

        footer h6 {
            color: var(--white);
            font-weight: 600;
            font-size: 0.85rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 18px;
        }

        .footer-link {
            display: block;
            color: rgba(255,255,255,0.4);
            font-size: 0.87rem;
            text-decoration: none;
            padding: 4px 0;
            transition: color 0.2s;
        }

            .footer-link:hover {
                color: var(--gold);
            }

        .footer-contact-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 10px;
        }

            .footer-contact-item i {
                color: var(--gold);
                font-size: 0.95rem;
                margin-top: 2px;
            }

            .footer-contact-item span {
                font-size: 0.87rem;
                color: rgba(255,255,255,0.5);
            }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.07);
            margin-top: 48px;
            padding-top: 22px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

            .footer-bottom p {
                margin: 0;
                font-size: 0.82rem;
                color: rgba(255,255,255,0.3);
            }

            .footer-bottom a {
                color: var(--gold);
                text-decoration: none;
            }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--dark);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .hero {
                padding: 80px 0;
                min-height: auto;
            }

            .hero-visual {
                margin-top: 50px;
            }

            .plan-card {
                margin-bottom: 30px;
            }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="https://bkinfotech.net/" target="_blank">
                <img src="~/CompanyLogos/bk-infotech.png" alt="BK-InfoTech Logo" />
                <div class="brand-text">
                    <span class="brand-name">ePharmacy</span>
                    <span class="brand-sub">by BK-InfoTech</span>
                </div>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" style="color:var(--gold)">
                <i class="bi bi-list fs-4"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-1 py-3 py-lg-0">
                    <li class="nav-item"><a class="nav-link" href="#features">Features</a></li>
                    <li class="nav-item"><a class="nav-link" href="#modules">Modules</a></li>
                    <li class="nav-item"><a class="nav-link" href="#pricing">Pricing</a></li>
                    <li class="nav-item"><a class="nav-link" href="#why-us">Why Us</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                    <li class="nav-item ms-lg-2"><a class="nav-link btn-nav-cta" href="@Url.Action("Index", "UserLogin", new { Area = "UserManagement" })">Get Started</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <section class="hero" id="home">
        <div class="container">
            <div class="row align-items-center gy-5">
                <div class="col-lg-6">
                    <div class="hero-pill">
                        <i class="bi bi-capsule-pill me-2"></i>Pharmacy Management System
                    </div>
                    <h1>Manage Your <span>Pharmacy</span> Smarter & Faster</h1>
                    <p>ePharmacy is a complete pharmacy management solution — from stock control to billing, purchases, employee records, and full financial accounting. Built for Pakistan's growing pharmacy market.</p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="#pricing" class="btn-primary-hero">View Pricing Plans</a>
                        <a href="#features" class="btn-outline-hero">Explore Features</a>
                    </div>
                    <div class="d-flex gap-4 mt-5">
                        <div>
                            <div style="font-size:1.6rem;font-weight:700;color:var(--gold);font-family:'Playfair Display',serif;">500+</div>
                            <div style="font-size:0.78rem;color:rgba(255,255,255,0.45);letter-spacing:1px;">Pharmacies Trusted</div>
                        </div>
                        <div style="width:1px;background:rgba(255,255,255,0.1);"></div>
                        <div>
                            <div style="font-size:1.6rem;font-weight:700;color:var(--gold);font-family:'Playfair Display',serif;">3</div>
