    <script>
        function showModule(name) {
            const modules = ['stock', 'pos', 'purchase', 'reports', 'employee', 'finance'];
            modules.forEach(m => {
                document.getElementById('mod-' + m).style.display = (m === name) ? 'block' : 'none';
            });
            document.querySelectorAll('.module-tab-btn').forEach((btn, i) => {
                btn.classList.toggle('active', modules[i] === name);
            });
        }

        // Scroll reveal
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.style.opacity = '1';
                    e.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.12 });

        document.querySelectorAll('.feature-card, .why-card, .plan-card, .testimonial-card').forEach(el => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(24px)';
            el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            observer.observe(el);
        });
    </script>
